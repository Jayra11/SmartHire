# ============================================
# Jetski SmartHire - Environment Configuration
# ============================================

# --- Google Gemini API ---
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (options: gemini-1.5-flash, gemini-1.5-pro, gemini-pro)
GEMINI_MODEL=gemini-1.5-flash

# --- Backend ---
BACKEND_URL=http://localhost:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Frontend ---
REACT_APP_API_URL=http://localhost:8000

# --- Environment ---
ENVIRONMENT=development

# ============================================
# Google Cloud (RAG, persistent storage, GenAI)
# ============================================
# Leave these unset for local dev — the app will automatically fall back
# to local disk storage and an in-memory database.

# GCP project ID (enables Firestore persistence)
GOOGLE_CLOUD_PROJECT=

# GCS bucket name for storing uploaded resume files (enables cloud storage)
GCS_BUCKET_NAME=

# Path to a service account JSON key with Storage + Firestore access
# (not needed on Cloud Run / GCE, which use the attached service account)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
